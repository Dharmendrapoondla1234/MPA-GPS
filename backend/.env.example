# ── Server ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
BIGQUERY_DATASET=mpa_gps
GOOGLE_APPLICATION_CREDENTIALS=./creds.json

# ── Equasis Credentials (Primary maritime data source) ──────────────────
EQUASIS_EMAIL=your.email@example.com
EQUASIS_PASSWORD=your_password_here

# ── AI APIs ─────────────────────────────────────────────────────────────
# Google Gemini AI (Free tier: 15 req/min, 1500 req/day)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCS5ZHl3feQx34UcQkY9H5WFfheJyCaS0U
GOOGLE_GEMINI_API_KEY=

# Optional: Google Custom Search Engine
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Optional: Email Validation APIs ─────────────────────────────────────
HUNTER_API_KEY=
ZEROBOUNCE_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_random_secret
JWT_EXPIRES_IN=7d

# ── AIS Tracking ─────────────────────────────────────────────────────────
MARINETRAFFIC_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
