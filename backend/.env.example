# ════════════════════════════════════════════════════════════════════
# MPA Maritime Intelligence Platform — Backend Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=development

# ── Google BigQuery ──────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=MPA
BIGQUERY_LOCATION=asia-southeast1

# Paste the full JSON content of your GCP service account key here.
# In production (Render), paste the entire JSON as one line.
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── AI / LLM API Keys ────────────────────────────────────────────────

# Google Gemini API (SOLE AI ENGINE — required for all AI features)
# Free tier: 15 req/min, 1500 req/day — no credit card needed
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# NOTE: Claude/Anthropic is NOT used. Remove ANTHROPIC_API_KEY if present.

# ── Google Maps (Frontend) ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Vessel Contact Enrichment (Optional) ─────────────────────────────
# Equasis.org login for vessel owner/manager lookup
EQUASIS_USER=your-email@example.com
EQUASIS_PASS=your-equasis-password

# Google Custom Search Engine (enhances contact discovery)
GOOGLE_CSE_API_KEY=AIza...
GOOGLE_CSE_ID=...

# ── Frontend URL (for CORS) ──────────────────────────────────────────
FRONTEND_URL=https://vessel-frontend.onrender.com

# ── Render Keep-Alive ────────────────────────────────────────────────
# Automatically set by Render:
# RENDER_EXTERNAL_URL=https://vessel-backend.onrender.com
