{
  "name": "vessel-backend",
  "version": "2.0.0",
  "description": "MarineTrack vessel tracking backend — BigQuery + Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
